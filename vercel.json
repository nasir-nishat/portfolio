{
    "redirects": [
        {
            "source": "/project",
            "destination": "/project/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/project/:path*",
            "destination": "https://threejs-projects-chi.vercel.app/:path*"
        }
    ],
    "headers": [
        {
            "source": "/project/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Cache-Control",
                    "value": "s-maxage=0"
                }
            ]
        }
    ]
}