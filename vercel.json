{
    "redirects": [
        {
            "source": "/project",
            "destination": "/project/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/project/:path*",
            "destination": "https://threejs-projects-chi.vercel.app/:path*"
        }
    ],
    "headers": [
        {
            "source": "/project/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000"
                }
            ]
        }
    ]
}