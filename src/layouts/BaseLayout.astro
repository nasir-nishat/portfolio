---
import "../styles/global.css";
import { profile, seo } from "../data/portfolio";

interface Props {
	title?: string;
	description?: string;
}

const { title = seo.title, description = seo.description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={seo.keywords.join(", ")} />
		<meta name="author" content={profile.name} />
		<meta name="robots" content="index,follow" />

		<link rel="canonical" href="/" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content={profile.name} />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<script>
		(function(w: Window & { [key: string]: any }, d: Document, s: string, l: string, i: string) {
			w[l] = w[l] || [];
			w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
			var f = d.getElementsByTagName(s)[0],
			j = d.createElement(s),
			dl = l != 'dataLayer' ? '&l=' + l : '';
			(j as HTMLScriptElement).async = true;
			(j as HTMLScriptElement).src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
			if (f.parentNode) {
				f.parentNode.insertBefore(j, f);
			}
		})(window, document, 'script', 'dataLayer', 'GTM-T2KN98LW');
		</script>

		<noscript>
			<iframe
			src="https://www.googletagmanager.com/ns.html?id=GTM-T2KN98LW"
			height="0"
			width="0"
			style="display:none;visibility:hidden"
			></iframe>
		</noscript>
	</head>
	<body class="min-h-screen bg-[#F7F8FC] text-zinc-900 antialiased selection:bg-[#2563EB] selection:text-white">
		<a
			href="#content"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-zinc-100 focus:px-3 focus:py-2 focus:text-zinc-950"
		>
			Skip to content
		</a>

		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute -top-20 right-[-6rem] h-80 w-80 rounded-full bg-blue-100/70 blur-3xl"></div>
			<div class="absolute top-1/3 left-[-8rem] h-72 w-72 rounded-full bg-blue-50/80 blur-3xl"></div>
		</div>

		<header class="fixed top-4 inset-x-0 z-50 flex justify-center pointer-events-none px-4">
			<nav class="group pointer-events-auto flex items-center gap-3 rounded-full border border-black/10 bg-white/80 p-2 backdrop-blur-lg shadow-sm transition-all duration-300 hover:shadow-md">
				<a href="/" class="px-3 py-2 text-sm font-bold tracking-tight hover:text-[#2563EB] transition-colors">
					Nasir Nishat
				</a>
				<div class="h-4 w-px bg-black/10 mx-1"></div>

				<div class="flex items-center gap-1 text-sm font-medium text-zinc-500">
					<a class="rounded-full px-3 py-2 hover:bg-black/5 hover:text-zinc-900 transition-all whitespace-nowrap" href="/projects/">Projects</a>
					<a class="rounded-full px-3 py-2 hover:bg-black/5 hover:text-zinc-900 transition-all whitespace-nowrap hidden lg:block group-hover:block" href="/#experience">Experience</a>
					<a class="rounded-full px-3 py-2 hover:bg-black/5 hover:text-zinc-900 transition-all whitespace-nowrap" href="/blogs/">Blog</a>
					<a class="rounded-full px-3 py-2 hover:bg-black/5 hover:text-zinc-900 transition-all whitespace-nowrap hidden lg:block group-hover:block" href="/#contact">Contact</a>
				</div>

				<div class="h-4 w-px bg-black/10 mx-1"></div>
				<a
					href={profile.whatsapp}
					target="_blank"
					rel="noreferrer"
					class="hidden sm:flex h-9 items-center justify-center rounded-full bg-[#2563EB] px-4 text-xs font-bold text-white transition hover:bg-[#1D4ED8] active:scale-[0.98]"
				>
					Let's talk
				</a>
			</nav>
		</header>

		<main id="content" class="mx-auto max-w-5xl px-4 pt-20">
			<slot />
		</main>

		<footer class="border-t border-black/[0.07] py-6 mt-4">
			<div class="mx-auto flex max-w-5xl flex-col gap-3 px-4 text-sm text-zinc-400 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<a href="/hidden-project/" class="hover:text-zinc-700 transition-colors">
						© {new Date().getFullYear()} {profile.name}
					</a>
				</div>
				<div class="flex gap-4">
					<a class="hover:text-zinc-700 transition-colors" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
					<a class="hover:text-zinc-700 transition-colors" href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
				</div>
			</div>
		</footer>

		<script>
			// Scroll reveal
			const els = document.querySelectorAll(".reveal");
			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (e.isIntersecting) e.target.classList.add("is-visible");
					}
				},
				{ threshold: 0.08 }
			);
			els.forEach((el) => io.observe(el));

			// Phone reveal
			document.querySelectorAll("[data-phone]").forEach((node) => {
				const el = node as HTMLElement;
				el.addEventListener("click", (e) => {
					if (el.tagName === "BUTTON") {
						e.preventDefault();
						const tel = el.dataset.phone;
						if (!tel) return;
						el.classList.remove("phone-hidden");
						el.classList.add("phone-visible");
						const a = document.createElement("a");
						a.href = tel;
						a.className = el.className.replace("phone-hidden", "").replace("phone-visible", "");
						a.textContent = el.textContent;
						el.replaceWith(a);
					} else if (el.tagName === "SPAN") {
						e.preventDefault();
						const tel = el.dataset.phone;
						if (!tel) return;
						el.classList.remove("phone-hidden");
						el.classList.add("phone-visible");
						const parent = el.closest("[data-phone-link]");
						if (parent instanceof HTMLAnchorElement) parent.href = tel;
					}
				});
			});
		</script>
	</body>
</html>
