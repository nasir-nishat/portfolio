---
import BaseLayout from "../layouts/BaseLayout.astro";
import { hiddenProjects } from "../data/portfolio";
---

<BaseLayout title="Hidden Projects">
	<section class="py-8 sm:py-12">
		<div class="reveal">
			<h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Projects</h1>
			<p class="mt-2 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400">
				A curated list of projects built for clients and partners.
			</p>
		</div>

		{hiddenProjects.length === 0 ? (
			<div class="mt-10 text-sm text-zinc-400 dark:text-zinc-600">No projects listed yet.</div>
		) : (
			<div class="mt-10 grid gap-4">
				{hiddenProjects.map((p) => (
					<article class="reveal overflow-hidden rounded-3xl border border-black/5 bg-white/40 p-5 backdrop-blur-xl transition-all duration-300 hover:bg-white/60 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10">
						<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
							<div class="flex-1">
								<h2 class="text-lg font-bold tracking-tight sm:text-xl">{p.name}</h2>
								{p.description && (
									<p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
										{p.description}
									</p>
								)}
							</div>
							{p.link && (
								<div class="flex items-center gap-3 sm:flex-none">
									<a
										href={p.link}
										target="_blank"
										rel="noreferrer"
										class="inline-flex h-9 items-center gap-1.5 rounded-full bg-indigo-600 px-4 text-xs font-bold text-white transition hover:bg-indigo-700 active:scale-[0.98]"
									>
										View
										<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
											<polyline points="15 3 21 3 21 9"></polyline>
											<line x1="10" y1="14" x2="21" y2="3"></line>
										</svg>
									</a>
								</div>
							)}
						</div>
					</article>
				))}
			</div>
		)}
	</section>
</BaseLayout>
