---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{seo.title}</title>
		<meta name="description" content={seo.description} />
		<meta name="keywords" content={seo.keywords.join(", ")} />
		<meta name="author" content={profile.name} />
		<meta name="robots" content="index,follow" />

		<link rel="canonical" href="/" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={seo.title} />
		<meta property="og:description" content={seo.description} />
		<meta property="og:site_name" content={profile.name} />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={seo.title} />
		<meta name="twitter:description" content={seo.description} />

		<script is:inline>
			// Theme: default follows system. Only overrides if user explicitly toggles.
			(() => {
				const root = document.documentElement;
				const stored = localStorage.getItem("theme"); // "light" | "dark" | null
				const mq = window.matchMedia?.("(prefers-color-scheme: dark)");

				const apply = (mode) => {
					if (mode === "dark") root.classList.add("dark");
					else root.classList.remove("dark");
				};

				const system = () => (mq && mq.matches ? "dark" : "light");

				apply(stored === "light" || stored === "dark" ? stored : system());

				// Keep following system changes unless user set an override.
				mq?.addEventListener?.("change", () => {
					const stillFollowingSystem = localStorage.getItem("theme") == null;
					if (stillFollowingSystem) apply(system());
				});
			})();
		</script>

		<script type="application/ld+json" is:inline>
			{JSON.stringify(
				{
					"@context": "https://schema.org",
					"@graph": [
						{
							"@type": "Person",
							name: profile.name,
							jobTitle: profile.title,
							email: `mailto:${profile.email}`,
							address: { "@type": "PostalAddress", addressLocality: "Seoul", addressCountry: "KR" },
							sameAs: [profile.github, profile.linkedin],
							knowsAbout: [
								"Flutter",
								"TypeScript",
								"Supabase",
								"AI agents",
								"No-code platforms",
								"WebSockets",
								"Product development",
							],
						},
						{
							"@type": "WebSite",
							name: profile.name,
							url: "/",
							description: seo.description,
						},
						{
							"@type": "FAQPage",
							mainEntity: [
								{
									"@type": "Question",
									name: "What do you build?",
									acceptedAnswer: {
										"@type": "Answer",
										text: "No-code platforms, AI agent experiences, and multi-platform apps (mobile/web/desktop) with a focus on shipping fast and iterating based on real usage.",
									},
								},
								{
									"@type": "Question",
									name: "Can you build an MVP quickly?",
									acceptedAnswer: {
										"@type": "Answer",
										text: "Yes—tight scope, clear milestones, and delivery-first execution to get a real version in users’ hands quickly.",
									},
								},
								{
									"@type": "Question",
									name: "Do you work with AI integrations?",
									acceptedAnswer: {
										"@type": "Answer",
										text: "Yes—agent-style workflows and LLM integrations, plus realtime updates where it improves the product experience.",
									},
								},
							],
						},
					],
				},
				null,
				0
			)}
		</script>
	</head>
	<body class="min-h-screen bg-zinc-50 text-zinc-900 antialiased selection:bg-zinc-900 selection:text-zinc-50 dark:bg-zinc-950 dark:text-zinc-100 dark:selection:bg-zinc-100 dark:selection:text-zinc-950">
		<a href="#content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-zinc-100 focus:px-3 focus:py-2 focus:text-zinc-950">
			Skip to content
		</a>

		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute -top-24 left-1/2 h-80 w-[46rem] -translate-x-1/2 rounded-full bg-gradient-to-r from-indigo-500/25 via-fuchsia-500/25 to-cyan-500/25 blur-3xl dark:from-indigo-500/20 dark:via-fuchsia-500/20 dark:to-cyan-500/20"></div>
			<div class="absolute bottom-[-10rem] right-[-8rem] h-80 w-80 rounded-full bg-cyan-500/15 blur-3xl dark:bg-cyan-500/10"></div>
		</div>

		<header class="sticky top-0 z-40 border-b border-black/10 bg-zinc-50/70 backdrop-blur dark:border-white/10 dark:bg-zinc-950/60">
			<nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
				<a href="#" class="font-semibold tracking-tight">{profile.name}</a>
				<div class="hidden items-center gap-6 text-sm text-zinc-600 sm:flex dark:text-zinc-300">
					<a class="hover:text-zinc-950 dark:hover:text-white" href="#work">Work</a>
					<a class="hover:text-zinc-950 dark:hover:text-white" href="#experience">Experience</a>
					<a class="hover:text-zinc-950 dark:hover:text-white" href="#blog">Blog</a>
					<a class="hover:text-zinc-950 dark:hover:text-white" href="#skills">Skills</a>
					<a class="hover:text-zinc-950 dark:hover:text-white" href="#contact">Contact</a>
				</div>
				<div class="flex items-center gap-2">
					<button
						id="theme-toggle"
						type="button"
						class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-white/70 text-zinc-900 transition hover:bg-white active:scale-[0.99] dark:border-white/15 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
						aria-label="Toggle dark mode"
						title="Toggle theme"
					>
						<svg id="theme-icon-sun" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z" stroke="currentColor" stroke-width="2"/>
							<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
						</svg>
						<svg id="theme-icon-moon" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path d="M21 13.2A7.8 7.8 0 1 1 10.8 3a6.2 6.2 0 0 0 10.2 10.2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
						</svg>
					</button>
					<a
						href={"mailto:" + profile.email}
						class="rounded-xl bg-zinc-900 px-3 py-2 text-sm font-semibold text-zinc-50 transition hover:opacity-90 active:scale-[0.99] dark:bg-white dark:text-zinc-950"
					>
						Email
					</a>
				</div>
			</nav>
		</header>

		<main id="content" class="mx-auto max-w-5xl px-4">
			<section class="py-10 sm:py-14">
				<div class="grid items-start gap-8 sm:grid-cols-[1.5fr_0.8fr]">
					<div class="reveal">
						<p class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-black/[0.03] px-3 py-1 text-xs text-zinc-700 dark:border-white/10 dark:bg-white/5 dark:text-zinc-200">
							<span class="h-1.5 w-1.5 rounded-full bg-emerald-600 dark:bg-emerald-400"></span>
							{profile.location}
						</p>
						<h1 class="mt-5 text-3xl font-semibold tracking-tight leading-[1.1] sm:mt-6 sm:text-5xl sm:leading-[1.05]">
							I help teams ship products fast.
						</h1>
						<p class="mt-4 max-w-2xl text-sm leading-relaxed text-zinc-700 sm:text-base dark:text-zinc-300">
							I’m {profile.name}, a Seoul-based engineer building no-code platforms, AI agent experiences, and multi-platform apps with a delivery-first mindset.
						</p>

						<div class="mt-6 flex flex-wrap gap-3">
							<a
								href="#work"
								class="rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-zinc-50 transition hover:opacity-90 active:scale-[0.99] dark:bg-white dark:text-zinc-950"
							>
								See work
							</a>
							<a
								href={"mailto:" + profile.email}
								class="rounded-xl border border-black/10 bg-black/[0.03] px-4 py-2 text-sm font-semibold text-zinc-900 transition hover:bg-black/[0.05] active:scale-[0.99] dark:border-white/15 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
							>
								Email me
							</a>
							<a
								href={profile.github}
								target="_blank"
								rel="noreferrer"
								class="rounded-xl border border-black/10 bg-black/[0.03] px-4 py-2 text-sm font-semibold text-zinc-900 transition hover:bg-black/[0.05] dark:border-white/15 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
							>
								GitHub
							</a>
						</div>
					</div>

					<div class="reveal rounded-2xl border border-black/10 bg-white/70 p-4 dark:border-white/10 dark:bg-white/5">
						<div class="text-xs text-zinc-500 dark:text-zinc-400">Quick info</div>
						<div class="mt-3 space-y-2 text-sm">
							<div class="flex items-center justify-between gap-3">
								<span class="text-zinc-500 dark:text-zinc-400">Role</span>
								<span class="text-zinc-900 dark:text-zinc-100">{profile.title}</span>
							</div>
							<div class="flex items-center justify-between gap-3">
								<span class="text-zinc-500 dark:text-zinc-400">Email</span>
								<a class="text-zinc-900 hover:underline dark:text-zinc-100" href={"mailto:" + profile.email}>{profile.email}</a>
							</div>
							<div class="flex items-center justify-between gap-3">
								<span class="text-zinc-500 dark:text-zinc-400">Phone</span>
									<button
										type="button"
										data-phone={"tel:" + profile.phone.replaceAll("-", "")}
										aria-label="Reveal phone number"
										aria-expanded="false"
										class="phone-toggle phone-hidden text-zinc-900 hover:underline dark:text-zinc-100"
									>
										{profile.phone}
									</button>
							</div>
							<div class="flex items-center justify-between gap-3">
								<span class="text-zinc-500 dark:text-zinc-400">LinkedIn</span>
								<a class="text-zinc-900 hover:underline dark:text-zinc-100" href={profile.linkedin} target="_blank" rel="noreferrer">Open</a>
							</div>
						</div>
						<div class="mt-4 flex flex-wrap gap-2">
							{["Flutter", "TypeScript", "Supabase"].map((t) => (
								<span class="rounded-full border border-black/10 bg-black/[0.03] px-2 py-1 text-[11px] text-zinc-700 dark:border-white/10 dark:bg-black/20 dark:text-zinc-200">{t}</span>
							))}
						</div>
					</div>
				</div>
			</section>

			<section class="py-8">
				<div class="grid gap-3 sm:grid-cols-3">
					{[
						{ title: "MVP to launch", desc: "Tight scope, fast builds, and a clean path to version 1." },
						{ title: "AI + realtime UX", desc: "Agents and collaboration where it actually improves workflow." },
						{ title: "Multi‑platform delivery", desc: "One product experience across mobile, web, and desktop." },
					].map((card) => (
						<div class="reveal card-hover rounded-2xl border border-black/10 bg-white/70 p-4 dark:border-white/10 dark:bg-white/5">
							<div class="text-sm font-semibold">{card.title}</div>
							<div class="mt-1 text-sm text-zinc-700 dark:text-zinc-300">{card.desc}</div>
						</div>
					))}
				</div>
			</section>

			<section id="work" class="py-10">
				<div class="flex items-end justify-between gap-4">
					<h2 class="text-xl font-semibold tracking-tight">Work</h2>
					<p class="text-sm text-zinc-500 dark:text-zinc-400">Two examples (kept short)</p>
				</div>

				<div class="mt-4 grid gap-4 sm:grid-cols-2">
					{projects.map((p) => (
						<article class="reveal card-hover rounded-2xl border border-black/10 bg-white/70 p-5 dark:border-white/10 dark:bg-white/5">
							<div class="flex flex-wrap items-start justify-between gap-3">
								<div>
									<h3 class="text-base font-semibold">{p.name}</h3>
									<p class="mt-1 text-sm text-zinc-700 dark:text-zinc-300">{p.oneLiner}</p>
								</div>
								<div class="flex flex-wrap gap-2">
									{p.stack.map((t) => (
										<span class="rounded-full border border-black/10 bg-black/[0.03] px-2 py-1 text-[11px] text-zinc-700 dark:border-white/10 dark:bg-black/20 dark:text-zinc-200">{t}</span>
									))}
								</div>
							</div>

							<details class="mt-4">
								<summary class="cursor-pointer select-none text-sm font-semibold text-zinc-900 hover:text-zinc-950 dark:text-white/90 dark:hover:text-white">
									Details
								</summary>
								<ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-zinc-700 dark:text-zinc-300">
									{p.details.map((d) => (
										<li>{d}</li>
									))}
								</ul>
							</details>
						</article>
					))}
				</div>
			</section>

			<section id="experience" class="py-10">
				<h2 class="text-xl font-semibold tracking-tight">Experience</h2>
				<div class="mt-4 space-y-3">
					{experience.map((e) => (
						<details class="reveal rounded-2xl border border-black/10 bg-white/70 p-5 dark:border-white/10 dark:bg-white/5">
							<summary class="cursor-pointer select-none">
								<div class="flex flex-wrap items-baseline justify-between gap-2">
									<div class="text-sm font-semibold">{e.company} · <span class="text-zinc-700 dark:text-zinc-200">{e.role}</span></div>
									<div class="text-xs text-zinc-500 dark:text-zinc-400">{e.when}</div>
								</div>
							</summary>
							<ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-zinc-700 dark:text-zinc-300">
								{e.highlights.map((h) => (
									<li>{h}</li>
								))}
							</ul>
						</details>
					))}
				</div>
			</section>

			<section id="blog" class="py-10">
				<div class="flex items-end justify-between gap-4">
					<h2 class="text-xl font-semibold tracking-tight">Blog</h2>
					<p class="text-sm text-zinc-500 dark:text-zinc-400">I’ll add real posts here soon</p>
				</div>

				<div class="mt-4 grid gap-4 sm:grid-cols-3">
					{blogPosts.map((p) => (
						<article class="reveal card-hover rounded-2xl border border-black/10 bg-white/70 p-5 dark:border-white/10 dark:bg-white/5">
							<div class="flex items-center justify-between gap-3">
								<span class="rounded-full border border-black/10 bg-black/[0.03] px-2 py-1 text-[11px] font-semibold text-zinc-700 dark:border-white/10 dark:bg-black/20 dark:text-zinc-200">
									{p.tag}
								</span>
								<span class="text-xs text-zinc-500 dark:text-zinc-400">{p.date}</span>
							</div>
							<h3 class="mt-3 text-sm font-semibold leading-snug">{p.title}</h3>
							<p class="mt-2 text-sm text-zinc-700 dark:text-zinc-300">{p.excerpt}</p>
							<div class="mt-4 text-sm font-semibold text-zinc-900/70 dark:text-white/70">Coming soon</div>
						</article>
					))}
				</div>
			</section>

			<section id="skills" class="py-10">
				<div class="grid gap-4 sm:grid-cols-2">
					<div class="reveal rounded-2xl border border-black/10 bg-white/70 p-5 dark:border-white/10 dark:bg-white/5">
						<h2 class="text-xl font-semibold tracking-tight">Skills</h2>
						<div class="mt-4 flex flex-wrap gap-2">
							{skills.map((s) => (
								<span class="rounded-full border border-black/10 bg-black/[0.03] px-3 py-1 text-xs text-zinc-700 dark:border-white/10 dark:bg-black/20 dark:text-zinc-200">{s}</span>
							))}
						</div>
					</div>
					<div class="reveal rounded-2xl border border-black/10 bg-white/70 p-5 dark:border-white/10 dark:bg-white/5">
						<h2 class="text-xl font-semibold tracking-tight">Awards & Education</h2>
						<ul class="mt-4 space-y-2 text-sm text-zinc-700 dark:text-zinc-300">
							{awards.map((a) => (
								<li class="flex gap-2">
									<span class="mt-1 inline-block h-1.5 w-1.5 flex-none rounded-full bg-zinc-900/60 dark:bg-white/60"></span>
									<span>{a}</span>
								</li>
							))}
						</ul>
					</div>
				</div>
			</section>

			<section id="contact" class="py-10 pb-14">
				<div class="reveal rounded-2xl border border-black/10 bg-white/70 p-6 dark:border-white/10 dark:bg-white/5">
					<h2 class="text-xl font-semibold tracking-tight">Contact</h2>
					<p class="mt-2 text-sm text-zinc-700 dark:text-zinc-300">
						If you’re building something and want a fast, calm execution partner, send a short note. I’ll reply with next steps.
					</p>
					<div class="mt-5 flex flex-wrap gap-3">
						<a
							class="rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-zinc-50 transition hover:opacity-90 active:scale-[0.99] dark:bg-white dark:text-zinc-950"
							href={"mailto:" + profile.email}
						>
							{profile.email}
						</a>
						<a
							class="rounded-xl border border-black/10 bg-black/[0.03] px-4 py-2 text-sm font-semibold text-zinc-900 transition hover:bg-black/[0.05] dark:border-white/15 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
							href="#"
							data-phone-link
						>
							<span data-phone-text class="phone-toggle phone-hidden" data-phone={"tel:" + profile.phone.replaceAll("-", "")} aria-hidden="true">
								{profile.phone}
							</span>
							<span class="sr-only">Reveal phone number</span>
						</a>
						<a
							class="rounded-xl border border-black/10 bg-black/[0.03] px-4 py-2 text-sm font-semibold text-zinc-900 transition hover:bg-black/[0.05] dark:border-white/15 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
							href={profile.linkedin}
							target="_blank"
							rel="noreferrer"
						>
							LinkedIn
						</a>
					</div>
				</div>
			</section>
		</main>

		<footer class="border-t border-black/10 py-8 dark:border-white/10">
			<div class="mx-auto flex max-w-5xl flex-col gap-3 px-4 text-sm text-zinc-500 sm:flex-row sm:items-center sm:justify-between dark:text-zinc-400">
				<div>© {new Date().getFullYear()} {profile.name}</div>
				<div class="flex gap-4">
					<a class="hover:text-zinc-950 dark:hover:text-white" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
					<a class="hover:text-zinc-950 dark:hover:text-white" href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
				</div>
			</div>
		</footer>

		<script>
			// Icon-only theme toggle (system default; click sets override).
			(() => {
				const root = document.documentElement;
				const mq = window.matchMedia?.("(prefers-color-scheme: dark)");

				const apply = (mode) => {
					if (mode === "dark") root.classList.add("dark");
					else root.classList.remove("dark");
					updateIcon();
				};

				const system = () => (mq && mq.matches ? "dark" : "light");
				const current = () => (root.classList.contains("dark") ? "dark" : "light");

				const sun = document.getElementById("theme-icon-sun");
				const moon = document.getElementById("theme-icon-moon");
				const updateIcon = () => {
					const mode = current();
					sun?.classList.toggle("hidden", mode !== "dark"); // show sun when in dark (to switch to light)
					moon?.classList.toggle("hidden", mode === "dark"); // show moon when in light (to switch to dark)
				};
				updateIcon();

				document.getElementById("theme-toggle")?.addEventListener("click", () => {
					const next = current() === "dark" ? "light" : "dark";
					localStorage.setItem("theme", next);
					apply(next);
				});

				// If user clears override, we follow system again (future-proof hook).
				mq?.addEventListener?.("change", () => {
					if (localStorage.getItem("theme") == null) apply(system());
				});
			})();

			// Hide phone numbers by default (to reduce spam scraping).
			// On first tap/click, reveal and convert into a clickable `tel:` link.
			function revealPhone(el) {
				if (!el) return;
				const tel = el.dataset.phone;
				if (!tel) return;

				el.classList.remove("phone-hidden");
				el.classList.add("phone-visible");

				// Convert button to link for the header case.
				if (el.tagName === "BUTTON") {
					const a = document.createElement("a");
					a.href = tel;
					a.className = el.className.replace("phone-hidden", "").replace("phone-visible", "");
					a.textContent = el.textContent;
					el.replaceWith(a);
					return;
				}
			}

			document.querySelectorAll("[data-phone]").forEach((el) => {
				el.addEventListener("click", (e) => {
					// Header quick-info button
					if (el.tagName === "BUTTON") {
						e.preventDefault();
						revealPhone(el);
						return;
					}

					// Contact section: span inside an `<a href="#">`
					if (el.tagName === "SPAN") {
						e.preventDefault();
						const tel = el.dataset.phone;
						if (!tel) return;

						el.classList.remove("phone-hidden");
						el.classList.add("phone-visible");

						const parent = el.closest("[data-phone-link]");
						if (parent && parent.tagName === "A") parent.href = tel;
					}
				});
			});

			const els = document.querySelectorAll(".reveal");
			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (e.isIntersecting) e.target.classList.add("is-visible");
					}
				},
				{ threshold: 0.08 }
			);
			els.forEach((el) => io.observe(el));
		</script>
	</body>
</html>
