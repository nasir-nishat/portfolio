---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.localeCompare(a.data.date)
);
---

<BaseLayout title="Blog | Nasir Nishat">
	<section class="py-8 sm:py-12">
		<div class="reveal">
			<h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Writing</h1>
			<p class="mt-2 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400">
				Thoughts on AI agents, product engineering, and moving fast.
			</p>
		</div>

		<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-2">
			{
				blogPosts.map((p) => (
					<article class="reveal group relative flex flex-col justify-between overflow-hidden rounded-3xl border border-black/5 bg-white/40 p-6 backdrop-blur-xl transition-all duration-300 hover:bg-white/60 hover:shadow-2xl hover:shadow-indigo-500/10 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10">
						<div>
							<div class="flex items-center gap-2">
								<span class="rounded-full bg-indigo-500/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-indigo-600 dark:bg-indigo-500/20 dark:text-indigo-400">
									{p.data.tag}
								</span>
								<span class="text-[11px] font-medium text-zinc-500 dark:text-zinc-500">
									{p.data.date}
								</span>
							</div>
							
							<h2 class="mt-4 text-xl font-bold leading-tight tracking-tight text-zinc-900 group-hover:text-indigo-600 dark:text-white dark:group-hover:text-indigo-400 transition-colors">
								<a href={`/blogs/${p.id}/`} target="_blank" rel="noreferrer">
									<span class="absolute inset-0 z-20" />
									<span class="relative z-10">{p.data.title}</span>
								</a>
							</h2>
							
							<p class="mt-3 line-clamp-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
								{p.data.description}
							</p>
						</div>
						
						<div class="mt-6 flex items-center gap-1.5 text-xs font-bold text-indigo-600 dark:text-indigo-400">
							<span>Full post</span>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<line x1="5" y1="12" x2="19" y2="12"></line>
								<polyline points="12 5 19 12 12 19"></polyline>
							</svg>
						</div>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
