---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/portfolio";
---

<BaseLayout title="Projects | Nasir Nishat">
	<section class="py-12 sm:py-16">
		<div class="reveal">
			<h1 class="text-3xl font-semibold tracking-tight sm:text-5xl">Projects</h1>
			<p class="mt-4 max-w-2xl text-zinc-700 dark:text-zinc-300">
				A collection of things I've built, ranging from AI agents and marketplace platforms to 3D WebGL experiences.
			</p>
		</div>

		<div class="mt-12 grid gap-6">
			{
				projects.map((p) => (
					<article class="reveal rounded-2xl border border-black/10 bg-white/70 p-6 sm:p-8 dark:border-white/10 dark:bg-white/5 transition hover:bg-white/80 dark:hover:bg-white/10">
						<div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
							<div class="flex-1">
								<div class="flex flex-wrap items-center gap-3">
									<h2 class="text-xl font-semibold sm:text-2xl">
										{p.name}
									</h2>
									<div class="flex flex-wrap gap-2">
										{p.stack.map((t) => (
											<span class="rounded-full border border-black/10 bg-black/[0.03] px-2 py-1 text-[11px] font-medium text-zinc-700 dark:border-white/10 dark:bg-black/20 dark:text-zinc-200">
												{t}
											</span>
										))}
									</div>
								</div>
								<p class="mt-3 text-base text-zinc-700 dark:text-zinc-300">
									{p.oneLiner}
								</p>
								
								<div class="mt-6">
									<details class="group">
										<summary class="cursor-pointer select-none text-xs font-bold uppercase tracking-wider text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors list-none flex items-center gap-1">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-3.4 w-3.5 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
												<polyline points="9 18 15 12 9 6"></polyline>
											</svg>
											Key Highlights
										</summary>
										<ul class="mt-3 space-y-2 list-disc pl-5 text-zinc-700 dark:text-zinc-300 border-l border-zinc-200 dark:border-zinc-800 ml-1.5">
											{p.details.map((d) => (
												<li>{d}</li>
											))}
										</ul>
									</details>
								</div>
							</div>
							
							{p.link && (
								<div class="flex-none sm:mt-1">
									<a
										href={p.link}
										target="_blank"
										rel="noreferrer"
										class="inline-flex items-center gap-2 rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-zinc-50 transition hover:opacity-90 active:scale-[0.99] dark:bg-white dark:text-zinc-950"
									>
										View Live
										<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
											<polyline points="15 3 21 3 21 9"></polyline>
											<line x1="10" y1="14" x2="21" y2="3"></line>
										</svg>
									</a>
								</div>
							)}
						</div>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
