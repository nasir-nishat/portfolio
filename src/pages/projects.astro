---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/portfolio";
---

<BaseLayout title="Projects | Nasir Nishat">
	<section class="py-8 sm:py-12">
		<div class="reveal">
			<h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Projects</h1>
			<p class="mt-2 max-w-2xl text-sm text-zinc-600 dark:text-zinc-400">
				Solving problems through AI, code, and 3D experiences.
			</p>
		</div>

		<div class="mt-10 grid gap-4">
			{
				projects.map((p) => (
					<article class="reveal overflow-hidden rounded-3xl border border-black/5 
						bg-white/40 p-5 backdrop-blur-xl transition-all duration-300 
						hover:bg-white/60 
						dark:border-white/10 
						dark:bg-white/5 
						dark:hover:bg-white/10">
							<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
							<div class="flex-1">
								<div class="flex flex-wrap items-center gap-2.5">
									<h2 class="text-lg font-bold tracking-tight sm:text-xl">
										{p.name}
									</h2>	
									<div class="flex flex-wrap gap-1.5">
										{p.stack.map((t) => (
											<span class="rounded-full bg-zinc-900/5 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-zinc-600 dark:bg-white/10 dark:text-zinc-400">
												{t}
											</span>
										))}
									</div>
								</div>
								<p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
									{p.oneLiner}
								</p>
								
								<div class="mt-4">
									<details class="group">
										<summary class="cursor-pointer select-none text-[10px] font-bold uppercase tracking-widest text-zinc-400 hover:text-indigo-600 dark:text-zinc-500 dark:hover:text-indigo-400 transition-colors list-none flex items-center gap-1">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
												<polyline points="9 18 15 12 9 6"></polyline>
											</svg>
											Highlights
										</summary>
										<ul class="mt-2 space-y-1.5 border-l border-indigo-500/20 pl-4 ml-1.5 text-xs leading-relaxed text-zinc-600 dark:text-zinc-400">
											{p.details.map((d) => (
												<li>{d}</li>
											))}
										</ul>
									</details>
								</div>
							</div>
							
							<div class="flex items-center gap-3 sm:flex-none">
								{p.github && (
									<a
										href={p.github}
										target="_blank"
										rel="noreferrer"
										class="inline-flex h-9 items-center gap-1.5 rounded-full border border-black/10 bg-white/50 px-4 text-xs font-bold text-zinc-900 transition hover:bg-white active:scale-[0.98] dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/15"
									>
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
										Code
									</a>
								)}
								{p.link && (
									<a
										href={p.link}
										target="_blank"
										rel="noreferrer"
										class="inline-flex h-9 items-center gap-1.5 rounded-full bg-indigo-600 px-4 text-xs font-bold text-white transition hover:bg-indigo-700 active:scale-[0.98]"
									>
										Live
										<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
											<polyline points="15 3 21 3 21 9"></polyline>
											<line x1="10" y1="14" x2="21" y2="3"></line>
										</svg>
									</a>
								)}
							</div>
						</div>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
